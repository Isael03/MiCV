// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model CurriculumVitae {
  id                   String               @id @default(uuid())
  title                String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  personalInformation  PersonalInformation? @default(null)
  workExperiences      WorkExperience[]     @default(null)
  educations           Education[]          @default(null)
  languages            Language[]           @default(null)
  projects             Projects[]           @default(null)
  skills               Skill[]              @default(null)
}

model PersonalInformation {
  id               String  @id @default(uuid())
  name             String
  lastName         String
  email            String
  phone            String
  address          String
  photo            String?
  linkedin         String?
  github           String?
  website          String?
  professionalTitle String?
  cvId             String  @unique
  cv               CurriculumVitae @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model WorkExperience {
  id          String  @id @default(uuid())
  company     String
  position    String
  startDate   String
  endDate     String
  description String
  cvId        String
  cv          CurriculumVitae @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Education {
  id          String  @id @default(uuid())
  institution String
  startDate   String
  endDate     String
  degree      String?
  cvId        String
  cv          CurriculumVitae @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Language {
  id   String @id @default(uuid())
  name String
  level String @default("basic")
  cvId String
  cv   CurriculumVitae @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Projects {
  id           String   @id @default(uuid())
  name         String
  description  String
  url          String?
  technologies String?
  cvId         String
  cv           CurriculumVitae @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Skill {
  id   String @id @default(uuid())
  name String
  type String
  cvId String
  cv   CurriculumVitae @relation(fields: [cvId], references: [id], onDelete: Cascade)
}
